{
  "name": "lorchess",
  "version": "0.1.0",
  "description": "Chess web app — play LorFish (AI) or other users in real time.",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:reset": "node src/db/reset.js"
  },
  "dependencies": {
    "argon2": "0.44.0",
    "better-sqlite3": "12.11.1",
    "better-sqlite3-session-store": "0.1.0",
    "express": "5.1.0",
    "express-session": "1.19.0",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "socket.io-client": "4.8.3"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "argon2@0.44.0": true
  }
}
